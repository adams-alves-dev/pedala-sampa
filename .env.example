# Endpoint da Content API do Hygraph (público — usado para leitura no client e no server)
HYGRAPH_ENDPOINT=https://api-us-east-1.graphcms.com/v2/SEU_PROJETO/master

# Permanent Auth Token do Hygraph, usado APENAS pelas server routes.
# Permissões mínimas: create + read no stage Draft em Suggestion e Feedback
# (a mutation devolve o id lendo do Draft) + read em Group/GroupInfo (Published).
GRAPHQL_TOKEN=

# Cloudflare Turnstile (anti-bot do formulário de sugestões).
# Deixe TURNSTILE_ENABLED=false até ter as chaves — o form funciona sem ele.
TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=
NUXT_PUBLIC_TURNSTILE_SITE_KEY=

# Webhook do Discord para avisar a cada nova sugestão ou feedback (opcional — opt-in).
# Crie em: canal → Editar → Integrações → Webhooks → Novo webhook → copiar URL.
# Sem esta variável, o aviso fica desligado (o formulário funciona normalmente).
DISCORD_WEBHOOK_URL=
